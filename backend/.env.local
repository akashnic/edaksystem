# ----- Django Core -----
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=django-insecure-local-dev-key

# ----- Database (Local SQLite) -----
DATABASE_URL=sqlite:///db.sqlite3

# ----- Media Storage (Local) -----
# We'll stick to local storage for now to keep it simple, 
# or use the existing Cloudinary if you want to test that.
# For now, let's keep it purely local if possible.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
